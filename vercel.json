{
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "redirects": [
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "amorinne.vercel.app"
        }
      ],
      "destination": "https://amorinne.kr/$1",
      "permanent": true
    }
  ]
}
